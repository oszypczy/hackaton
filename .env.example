# Copy to .env and fill in your own values. Never commit .env.

# GitHub PAT — read-only, scope: public_repo
# Generate: github.com → Settings → Developer settings → PAT (classic) → public_repo
GITHUB_TOKEN=ghp_your_token_here

# Hackathon submission API key — given by organizers at start
# Used by `just submit <task> <csv>` to POST to http://35.192.205.84/submit/<TASK_ID>
# See docs/SUBMISSION_FLOW.md
HACKATHON_API_KEY=
